# === CORE ===
APP_ENV=development
SECRET_KEY=                    # 64-char random hex
JWT_SECRET=                    # 64-char random hex
JWT_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=30

# === DATABASE ===
DATABASE_URL=postgresql+asyncpg://faliz:password@localhost:5432/faliz
REDIS_URL=redis://localhost:6379/0
CHROMA_HOST=localhost
CHROMA_PORT=8000

# === AI / LLM ===
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
ANTHROPIC_API_KEY=             # Fallback LLM
OLLAMA_BASE_URL=http://localhost:11434  # Local fallback

# === VOICE ===
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
PICOVOICE_ACCESS_KEY=          # Wake word detection
WHISPER_MODEL=whisper-1        # Or local: medium

# === GOOGLE SERVICES ===
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
GOOGLE_CALENDAR_SCOPES=https://www.googleapis.com/auth/calendar
GMAIL_SCOPES=https://mail.google.com/
GOOGLE_MAPS_API_KEY=

# === EXTERNAL SERVICES ===
OPENWEATHER_API_KEY=
NEWS_API_KEY=
WOLFRAM_ALPHA_APP_ID=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_FROM=
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# === SMART HOME ===
HOME_ASSISTANT_URL=http://homeassistant.local:8123
HOME_ASSISTANT_TOKEN=

# === SECURITY ===
ENCRYPTION_KEY=               # 32-byte base64 for AES-256
FACE_AUTH_ENABLED=true
FACE_AUTH_CONFIDENCE=0.8

# === FEATURE FLAGS ===
PLUGIN_VOICE_ENABLED=true
PLUGIN_CALENDAR_ENABLED=true
PLUGIN_EMAIL_ENABLED=true
PLUGIN_SYSTEM_ENABLED=true
PLUGIN_SMARTHOME_ENABLED=false
PLUGIN_VISION_ENABLED=true
PLUGIN_ENTERTAINMENT_ENABLED=true
PLUGIN_ANALYTICS_ENABLED=true
